# Docker 部署环境变量 (P0-8)
# 复制此文件为 .env 并根据需要进行修改

# ── 应用 ─────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
ENV=prod

# ── 数据库 (PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://sciagent:sciagent@postgres:5432/sciagent

# ── JWT / 认证 ───────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-strong-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis 缓存 ───────────────────────────────────
CACHE_TYPE=redis
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── 外部 API ─────────────────────────────────────
KEYING_API_BASE=https://api.keying.com/v1
KEYING_API_KEY=
SCIENCERIVER_APP_ID=
SCIENCERIVER_APP_SECRET=

ARXIV_API_BASE=http://export.arxiv.org/api/query
PUBMED_API_BASE=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# ── 限流 ─────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── AI 模型 (M5) ──────────────────────────────────
WRITING_LLM_MODEL=gpt-4o
DEFAULT_MODEL_TIMEOUT=60
MAX_MODEL_TOKENS=4096

# ── Docker 沙箱 (M6) ─────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_DEFAULT_IMAGE=sci-agent/sandbox:latest
M6_SANDBOX_CPU_LIMIT=2.0
M6_SANDBOX_MEMORY_LIMIT_MB=2048
M6_SANDBOX_TIMEOUT_SECONDS=300
