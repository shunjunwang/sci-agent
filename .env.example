# ============================================================
# SciAgent — 环境变量模板
# 复制为 .env 并填入真实值。切勿将 .env 提交到版本控制。
# ============================================================

# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sci_agent

# ── JWT / 认证 ─────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-strong-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (逗号分隔多个源) ──────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── 应用 ───────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
ENV=dev
