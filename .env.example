# ============================================================
# SciAgent — 环境变量模板
# 复制为 .env 并填入真实值。切勿将 .env 提交到版本控制。
# ============================================================

# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./sci_agent.db

# ── JWT / 认证 ─────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-strong-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (逗号分隔多个源) ──────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── 应用 ───────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
ENV=dev

# ── M3 知识库 ──────────────────────────────────────────
# 全文搜索后端：postgres（需要 pg_trgm 扩展）或 sqlite（仅 LIKE 匹配）
KNOWLEDGE_SEARCH_BACKEND=sqlite
# 引用导出默认格式
DEFAULT_CITATION_FORMAT=gbt7714
# 阅读历史保留天数
READING_HISTORY_DAYS=90
